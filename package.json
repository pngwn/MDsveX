{
	"name": "mdsvex",
	"version": "0.8.5",
	"description": "Markdown preprocessor for Svelte",
	"repository": "https://github.com/pngwn/MDsveX",
	"type": "module",
	"scripts": {
		"test": "pnpm -r --filter=!site test",
		"test:run": "pnpm -r build && vitest run . ",
		"test:e2e": "pnpm --filter=mdsvex-demo test:e2e",
		"release": "pnpm --filter=!mdsvex-demo --filter=!@mdsvex/site build && changeset publish",
		"changeset:add": "changeset add",
		"changeset:pre-enter": "changeset pre enter",
		"changeset:pre-exit": "changeset pre exit",
		"changeset:version": "changeset version && pnpm i --lockfile-only",
		"site:dev": "pnpm --filter @mdsvex/site dev",
		"site:build": "pnpm --filter @mdsvex/site build"
	},
	"keywords": [
		"test",
		"preprocessor",
		"mdx",
		"markdown",
		"svelte"
	],
	"author": "pngwn <hello@pngwn.io>",
	"license": "MIT",
	"devDependencies": {
		"@changesets/changelog-github": "^0.5.1",
		"@changesets/cli": "^2.28.1",
		"@types/node": "^22.15.2",
		"typescript": "^6.0.2"
	},
	"dependencies": {
		"playwright": "^1.52.0",
		"tslib": "^2.8.1",
		"vite": "^6.3.3",
		"vitest": "^3.1.2"
	},
	"engines": {
		"pnpm": "^10.33.0"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"packageManager": "pnpm@10.33.0"
}
