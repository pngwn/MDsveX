{
	"name": "mdsvex",
	"version": "0.12.5",
	"description": "Markdown preprocessor for Svelte",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/main.d.ts",
			"default": "./dist/main.js"
		},
		"./package.json": "./package.json",
		"./globals": {
			"types": "./globals.d.ts"
		}
	},
	"main": "dist/main.js",
	"module": "dist/main.js",
	"types": "./dist/main.d.ts",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/pngwn/MDsveX.git"
	},
	"scripts": {
	"build": "vite build --config vite.config.build.ts",
		"test": "vitest . **/*.spec.ts"
	},
	"files": [
		"dist/*",
		"globals.d.ts"
	],
	"keywords": [
		"test",
		"preprocessor",
		"mdx",
		"markdown",
		"svelte"
	],
	"author": "pngwn <hello@pngwn.io>",
	"license": "MIT",
	"dependencies": {
  	"@mdsvex/parse": "workspace:*",
  	"@mdsvex/render": "workspace:*"
	}
}
