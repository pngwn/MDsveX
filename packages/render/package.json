{
	"name": "@mdsvex/render",
	"version": "0.1.0",
	"description": "Renderers for the PFM parser wire format",
	"private": true,
	"type": "module",
	"scripts": {
		"test": "vitest --disableConsoleIntercept",
		"test:run": "vitest run --silent",
		"build": "vite build --config vite.config.build.ts"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./src/index.ts"
		},
		"./html-cursor": {
			"import": "./dist/html_cursor.js",
			"types": "./src/html_cursor.ts"
		},
		"./component": {
			"import": "./dist/component.js",
			"types": "./src/component.ts"
		},
		"./mappings": {
			"import": "./dist/mappings.js",
			"types": "./src/mappings.ts"
		},
		"./sourcemap": {
			"import": "./dist/sourcemap.js",
			"types": "./src/sourcemap.ts"
		},
		"./Node.svelte": {
			"types": "./src/Node.svelte",
			"svelte": "./src/Node.svelte",
			"import": "./src/Node.svelte"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"peerDependenciesMeta": {
		"svelte": {
			"optional": true
		}
	},

	"dependencies": {
		"@mdsvex/parse": "workspace:*"
	},
	"author": "pngwn <hello@pngwn.io>",
	"license": "MIT"
}
