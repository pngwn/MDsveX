{
	"name": "@mdsvex/render",
	"version": "0.1.0",
	"description": "Renderers for the PFM parser wire format",
	"private": true,
	"type": "module",
	"scripts": {
		"test": "vitest --disableConsoleIntercept",
		"test:run": "vitest run --silent"
	},
	"exports": {
		".": {
			"import": "./src/index.ts",
			"types": "./src/index.ts"
		},
		"./html": {
			"import": "./src/html.ts",
			"types": "./src/html.ts"
		},
		"./component": {
			"import": "./src/component.ts",
			"types": "./src/component.ts"
		},
		"./pixi": {
			"import": "./src/pixi.ts",
			"types": "./src/pixi.ts"
		},
		"./Node.svelte": {
			"types": "./src/Node.svelte",
			"svelte": "./src/Node.svelte",
			"import": "./src/Node.svelte"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0",
		"pixi.js": "^8.0.0"
	},
	"peerDependenciesMeta": {
		"svelte": {
			"optional": true
		},
		"pixi.js": {
			"optional": true
		}
	},
	"dependencies": {
		"@mdsvex/parse": "workspace:*"
	},
	"author": "pngwn <hello@pngwn.io>",
	"license": "MIT"
}
