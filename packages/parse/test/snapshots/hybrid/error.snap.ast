root
  html tag="script"
  line_break
  line_break
  html tag="style"
  line_break
  line_break
  heading depth=1 "{status}"
    mustache "status"
  line_break
  line_break
  paragraph
    mustache "error.message"
  line_break
  line_break
  svelte_block tag="if"
    svelte_branch tag="if" "dev && error.stack"
      line_break
      line_break
      html tag="pre"
        paragraph
          mustache "error.stack"
      line_break
      line_break
      paragraph
        mustache "/if"
        line_break