root
  html tag="script"
  line_break
  line_break
  html tag="style"
  line_break
  line_break
  html tag="div" style="position: absolute; right: 1em;"
    line_break
    html tag="label"
      line_break
      html tag="h3"
        paragraph
          text "stiffness ("
          mustache "coords.stiffness"
          text ")"
      line_break
      html tag="input" bind:value=[object Object] type="range" min="0" max="1" step="0.01"
        line_break
        paragraph
    line_break
    line_break
    html tag="label"
      line_break
      html tag="h3"
        paragraph
          text "damping ("
          mustache "coords.damping"
          text ")"
      line_break
      html tag="input" bind:value=[object Object] type="range" min="0" max="1" step="0.01"
        line_break
        paragraph
    line_break
  line_break
  line_break
  html tag="svg" on:mousemove="{e => coords.set({ x: e.clientX, y: e.clientY })}" on:mousedown="{() => size.set(30)}" on:mouseup="{() => size.set(10)}"
    line_break
    html tag="circle" cx=[object Object] cy=[object Object] r=[object Object] self_closing=true
    line_break