root
  html tag="script"
    line_break
    paragraph
      text "import "
      mustache " spring "
      text " from \"svelte/motion\";"
    line_break
    line_break
    paragraph
      text "let coords = spring(\n	"
      mustache " x: 50, y: 50 "
      text ",\n	"
      mustache "\n		stiffness: 0.1,\n		damping: 0.25,\n	"
      text ",\n);"
    line_break
    line_break
    paragraph
      text "let size = spring(10);\n"
  line_break
  line_break
  html tag="style"
    line_break
    paragraph
      text "svg "
      mustache " width: 100%; height: 100%; margin: -8px "
      text "	circle "
      mustache " fill: #ff3e00 "
  line_break
  line_break
  html tag="div" style="position: absolute; right: 1em;"
    line_break
    html tag="label"
      line_break
      html tag="h3"
        paragraph
          text "stiffness ("
          mustache "coords.stiffness"
          text ")"
      line_break
      html tag="input" bind:value="coords.stiffness" type="range" min="0" max="1" step="0.01"
        line_break
        paragraph
    line_break
    line_break
    html tag="label"
      line_break
      html tag="h3"
        paragraph
          text "damping ("
          mustache "coords.damping"
          text ")"
      line_break
      html tag="input" bind:value="coords.damping" type="range" min="0" max="1" step="0.01"
        line_break
        paragraph
    line_break
  line_break
  line_break
  html tag="svg" on:mousemove="{e => coords.set({ x: e.clientX, y: e.clientY })}" on:mousedown="{() => size.set(30)}" on:mouseup="{() => size.set(10)}"
    line_break
    html tag="circle" cx="$coords.x" cy="$coords.y" r="$size" self_closing=true
    line_break