root
  html_comment "\nhttps://eugenkiss.github.io/7guis/tasks#circle\n\nClick on the canvas to draw a circle. Click on a circle\nto select it. Right-click on the canvas to adjust the\nradius of the selected circle.\n"
  line_break
  line_break
  html tag="script"
    line_break
    paragraph
      text "let i = 0;\nlet undoStack = "
    line_break
    line_break
    paragraph
      text "function handleClick(event) "
      mustache "\n	if (adjusting) {\n		adjusting = false;\n\n		// if circle was adjusted,\n		// push to the stack\n		if (adjusted) push();\n		return;\n	}\n\n	const circle = {\n		cx: event.clientX,\n		cy: event.clientY,\n		r: 50,\n	};\n\n	circles = circles.concat(circle);\n	selected = circle;\n\n	push();\n"
    line_break
    line_break
    paragraph
      text "function adjust(event) "
      mustache "\n	selected.r = +event.target.value;\n	circles = circles;\n	adjusted = true;\n"
    line_break
    line_break
    paragraph
      text "function select(circle, event) "
      mustache "\n	if (!adjusting) {\n		event.stopPropagation();\n		selected = circle;\n	}\n"
    line_break
    line_break
    paragraph
      text "function push() "
      mustache "\n	const newUndoStack = undoStack.slice(0, ++i);\n	newUndoStack.push(clone(circles));\n	undoStack = newUndoStack;\n"
    line_break
    line_break
    paragraph
      text "function travel(d) "
      mustache "\n	circles = clone(undoStack[(i += d)]);\n	adjusting = false;\n"
    line_break
    line_break
    paragraph
      text "function clone(circles) "
      mustache "\n	return circles.map(({ cx, cy, r }) => ({ cx, cy, r }));\n"
  line_break
  line_break
  html tag="style"
    line_break
    paragraph
      text ".controls "
      mustache "\n		position: absolute;\n		width: 100%;\n		text-align: center;\n	"
      line_break
      line_break
      paragraph
        text "svg "
        mustache "\n		background-color: #eee;\n		width: 100%;\n		height: 100%;\n	"
      line_break
      line_break
      paragraph
        text "circle "
        mustache "\n		stroke: black;\n	"
      line_break
      line_break
      paragraph
        text ".adjuster "
        mustache "\n		position: absolute;\n		width: 80%;\n		top: 50%;\n		left: 50%;\n		transform: translate(-50%,-50%);\n		padding: 1em;\n		text-align: center;\n		background-color: rgba(255,255,255,0.7);\n		border-radius: 4px;\n	"
      line_break
      line_break
      paragraph
        text "input"
        text "] "
        mustache "\n		width: 100%;\n	"
  line_break
  line_break
  html tag="div" class="controls"
    line_break
    html tag="button" on:click="{() => travel(-1)}" disabled="{i === 0}"
      paragraph
        text "undo"
    line_break
    html tag="button" on:click="{() => travel(+1)}" disabled="{i === undoStack.length -1}"
      paragraph
        text "redo"
    line_break
  line_break
  line_break
  html tag="svg" on:click="handleClick"
    line_break
    paragraph
      mustache "#each circles as circle"
      text "		"
      html tag="circle" cx="circle.cx" cy="circle.cy" r="circle.r" on:click="{event => select(circle, event)}" on:contextmenu|stopPropagation|preventDefault="{() => {\n				adjusting = !adjusting;\n				if (adjusting) selected = circle;\n			}}" fill="{circle === selected ? '#ccc': 'white'}" self_closing=true
      text "	"
      mustache "/each"
  line_break
  line_break
  paragraph
    mustache "#if adjusting"
    text "	"
    html tag="div" class="adjuster"
      text "		"
      html tag="p"
        text "adjust diameter of circle at "
        mustache "selected.cx"
        text ", "
        mustache "selected.cy"
      text "		"
      html tag="input" type="range" value="selected.r" on:input="adjust"
        text "	"
    mustache "/if"