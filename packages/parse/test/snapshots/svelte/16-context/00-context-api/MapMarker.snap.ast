root
  html tag="script"
    line_break
    paragraph
      text "import "
      mustache " getContext "
      text " from \"svelte\";\nimport "
      mustache " mapbox, key "
      text " from \"./mapbox.js\";"
    line_break
    line_break
    paragraph
      text "const "
      mustache " getMap "
      text " = getContext(key);\nconst map = getMap();"
    line_break
    line_break
    paragraph
      text "export let lat;\nexport let lon;\nexport let label;"
    line_break
    line_break
    paragraph
      text "const popup = new mapbox.Popup("
      mustache " offset: 25 "
      text ").setText(label);"
    line_break
    line_break
    paragraph
      text "const marker = new mapbox.Marker()\n	.setLngLat("
      text "])\n	.setPopup(popup)\n	.addTo(map);\n"