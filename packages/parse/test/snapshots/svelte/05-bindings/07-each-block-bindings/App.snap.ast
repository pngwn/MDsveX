root
  html tag="script"
  line_break
  line_break
  html tag="style"
  line_break
  line_break
  html tag="h1"
    paragraph
      text "Todos"
  line_break
  line_break
  paragraph
    mustache "#each todos as todo"
    soft_break
    text "	"
    text tag="div" class:done=[object Object] "<div class:done={todo.done}>"
    soft_break
    text "		"
    text tag="input" type="checkbox" bind:checked=[object Object] "<input"
    line_break
    line_break
    text tag="input" placeholder="What needs to be done?" bind:value=[object Object] "<input"
    line_break
    paragraph
      text "</div>"
      soft_break
      mustache "/each"
    line_break
    line_break
    html tag="p"
      paragraph
        mustache "remaining"
        text " remaining"
    line_break
    line_break
    html tag="button" on:click=[object Object]
      line_break
      paragraph
        text "Add new"
        soft_break
    line_break
    line_break
    html tag="button" on:click=[object Object]
      line_break
      paragraph
        text "Clear completed"
        soft_break
    line_break