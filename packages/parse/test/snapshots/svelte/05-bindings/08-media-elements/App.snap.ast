root
  html tag="script"
  line_break
  line_break
  html tag="style"
  line_break
  line_break
  html tag="h1"
    paragraph
      text "Caminandes: Llamigos"
  line_break
  html tag="p"
    paragraph
      text "From "
      html tag="a" href="https://cloud.blender.org/open-projects"
        text "Blender Open Projects"
      text ". CC-BY"
  line_break
  line_break
  html tag="div"
    line_break
    html tag="video" poster="http://sveltejs.github.io/assets/caminandes-llamigos.jpg" src="http://sveltejs.github.io/assets/caminandes-llamigos.mp4" on:mousemove="handleMousemove" on:mousedown="handleMousedown" bind:currentTime="time" bind:duration=true bind:paused=true
    line_break
    line_break
    html tag="div" class="controls" style="opacity: {duration && showControls ? 1 : 0}"
      line_break
      html tag="progress" value="{(time / duration) || 0}" self_closing=true
      line_break
      line_break
      html tag="div" class="info"
        line_break
        html tag="span" class="time"
          paragraph
            mustache "format(time)"
        line_break
        html tag="span"
          paragraph
            text "click anywhere to "
            mustache "paused ? 'play' : 'pause'"
            text " / drag to seek"
        line_break
        html tag="span" class="time"
          paragraph
            mustache "format(duration)"
        line_break
      line_break
    line_break