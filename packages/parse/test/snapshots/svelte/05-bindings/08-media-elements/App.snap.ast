root
  html tag="script"
  line_break
  line_break
  html tag="h1"
    paragraph
      text "Caminandes: Llamigos"
  line_break
  html tag="p"
    line_break
    paragraph
      text "From "
      text tag="a" href="https://cloud.blender.org/open-projects" "<a "
      text "Blender Open Projects"
      text "</a"
      line_break
      paragraph
        text ">. CC-BY"
        soft_break
  line_break
  line_break
  html tag="div"
    line_break
    html tag="video" poster="http://sveltejs.github.io/assets/caminandes-llamigos.jpg" src="http://sveltejs.github.io/assets/caminandes-llamigos.mp4" on:mousemove=[object Object] on:mousedown=[object Object] bind:currentTime=[object Object] bind:duration=true bind:paused=true
    line_break
    line_break
    html tag="div" class="controls" style="opacity: {duration && showControls ? 1 : 0}"
      line_break
      html tag="progress" value=[object Object] self_closing=true
      line_break
      line_break
      html tag="div" class="info"
        line_break
        html tag="span" class="time"
          paragraph
            mustache "format(time)"
        line_break
        html tag="span"
          paragraph
            text "click anywhere to "
            mustache "paused ? 'play' : 'pause'"
            text " / drag to seek"
        line_break
        html tag="span" class="time"
          paragraph
            mustache "format(duration)"
        line_break
      line_break
    line_break
  line_break
  line_break
  html tag="style"
  line_break