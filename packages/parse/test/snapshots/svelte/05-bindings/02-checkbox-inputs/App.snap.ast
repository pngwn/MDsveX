root
  html tag="script"
    line_break
    paragraph
      text "let yes = false;\n"
  line_break
  line_break
  html tag="label"
    line_break
    html tag="input" type="checkbox" bind:checked="yes"
      line_break
      paragraph
        text "Yes"
        text "! Send me regular email spam\n"
  line_break
  line_break
  paragraph
    mustache "#if yes"
    text "	"
    html tag="p"
      text "Thank you. We will bombard your inbox and sell your personal details."
    mustache ":else"
    text "	"
    html tag="p"
      text "You must opt in to continue. If you're not paying, you're the product."
    mustache "/if"