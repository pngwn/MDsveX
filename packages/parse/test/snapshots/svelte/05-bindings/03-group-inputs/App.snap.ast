root
  html tag="script"
  line_break
  line_break
  html tag="h2"
    paragraph
      text "Size"
  line_break
  line_break
  html tag="label"
    line_break
    html tag="input" type="radio" bind:group="scoops" value="1"
      line_break
      paragraph
        text "One scoop"
        soft_break
  line_break
  line_break
  html tag="label"
    line_break
    html tag="input" type="radio" bind:group="scoops" value="2"
      line_break
      paragraph
        text "Two scoops"
        soft_break
  line_break
  line_break
  html tag="label"
    line_break
    html tag="input" type="radio" bind:group="scoops" value="3"
      line_break
      paragraph
        text "Three scoops"
        soft_break
  line_break
  line_break
  html tag="h2"
    paragraph
      text "Flavours"
  line_break
  line_break
  paragraph
    mustache "#each menu as flavour"
    soft_break
    text "	"
    html tag="label"
      soft_break
      text "		"
      html tag="input" type="checkbox" bind:group="flavours" value="flavour"
        soft_break
        text "		"
        mustache "flavour"
        soft_break
        text "	"
    soft_break
    mustache "/each"