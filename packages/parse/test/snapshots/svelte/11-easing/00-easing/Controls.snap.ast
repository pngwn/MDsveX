root
  html tag="script"
  line_break
  line_break
  html tag="style"
  line_break
  line_break
  html tag="div" class="easing-sidebar"
    line_break
    html tag="div" class="easing-types"
      line_break
      html tag="h3"
        paragraph
          text "Ease"
      line_break
      paragraph
        mustache "#if mobile"
        soft_break
        text "				"
        html tag="select" bind:value=[object Object]
          soft_break
          text "					"
          mustache "#each [...eases] as [name]"
          soft_break
          text "						"
          html tag="option" value=[object Object] class:selected=[object Object]
            soft_break
            text "							"
            mustache "name"
            soft_break
            text "						"
          soft_break
          text "					"
          mustache "/each"
          soft_break
          text "				"
        soft_break
        text "			"
        mustache ":else"
        soft_break
        text "				"
        html tag="ul"
          soft_break
          text "					"
          mustache "#each [...eases] as [name]"
          soft_break
          text "						"
          html tag="li" class:selected=[object Object] on:click=[object Object]
            soft_break
            text "							"
            mustache "name"
            soft_break
            text "						"
          soft_break
          text "					"
          mustache "/each"
          soft_break
          text "				"
        soft_break
        text "			"
        mustache "/if"
        soft_break
        text "			"
        html tag="h3"
          text "Type"
        soft_break
        text "			"
        mustache "#if mobile "
        soft_break
        text "				"
        html tag="select" bind:value=[object Object]
          soft_break
          text "					"
          mustache "#each types as [name, type]"
          soft_break
          text "						"
          html tag="option" value=[object Object]
            soft_break
            text "							"
            mustache "name"
            soft_break
            text "						"
          soft_break
          text "					"
          mustache "/each"
          soft_break
          text "				"
        soft_break
        text "			"
        mustache ":else"
        soft_break
        text "				"
        html tag="ul"
          soft_break
          text "					"
          mustache "#each types as [name, type]"
          soft_break
          text "						"
          html tag="li" class:selected=[object Object] on:click=[object Object]
            soft_break
            text "							"
            mustache "name"
            soft_break
            text "					"
          soft_break
          text "					"
          mustache "/each"
          soft_break
          text "				"
        soft_break
        text "			"
        mustache "/if"
        soft_break
        text "		"
    line_break
    html tag="h4"
      line_break
      paragraph
        text "Duration"
        soft_break
        text "		"
    line_break
    html tag="div" class="duration"
      line_break
      html tag="span"
        line_break
        html tag="input" type="number" bind:value=[object Object] min="0" step="100" self_closing=true
        line_break
        html tag="button" class="number" on:click=[object Object]
          paragraph
            text "-"
        line_break
        html tag="button" class="number" on:click=[object Object]
          paragraph
            text "+"
        line_break
      line_break
      html tag="button" class="play" on:click=[object Object]
        line_break
        paragraph
          mustache "playing ? 'Restart' : 'Play'"
          soft_break
          text "			"
      line_break
    line_break