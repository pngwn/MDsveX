  svelte_block tag="each"
    svelte_branch tag="each" "{ length: 8 } as _, i"
      line_break
      svelte_block tag="if"
        svelte_branch tag="if" "i < 6"
          line_break
          html tag="path" d="M{(i+1) * 200} 0 L{(i+1)*200} 1802" class="grid-line" self_closing=true
          line_break
