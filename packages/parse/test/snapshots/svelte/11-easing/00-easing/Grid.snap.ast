  html tag="path" style="transform: translateX({x+200}px)" d="M0 0 L0 1800" class="grid-line-xy" self_closing=true
  line_break
  html tag="path" style="transform: translateY({y}px)" d="M0 400 L1400 400" class="grid-line-xy" self_closing=true
