root
  html tag="script"
    line_break
    paragraph
      text "import "
      mustache " spring "
      text " from \"svelte/motion\";\nimport "
      mustache " pannable "
      text " from \"./pannable.js\";"
    line_break
    line_break
    paragraph
      text "const coords = spring(\n	"
      mustache " x: 0, y: 0 "
      text ",\n	"
      mustache "\n		stiffness: 0.2,\n		damping: 0.4,\n	"
      text ",\n);"
    line_break
    line_break
    paragraph
      text "function handlePanStart() "
      mustache "\n	coords.stiffness = coords.damping = 1;\n"
    line_break
    line_break
    paragraph
      text "function handlePanMove(event) "
      mustache "\n	coords.update(($coords) => ({\n		x: $coords.x + event.detail.dx,\n		y: $coords.y + event.detail.dy,\n	}));\n"
    line_break
    line_break
    paragraph
      text "function handlePanEnd(event) "
      mustache "\n	coords.stiffness = 0.2;\n	coords.damping = 0.4;\n	coords.set({ x: 0, y: 0 });\n"
  line_break
  line_break
  html tag="style"
    line_break
    paragraph
      text ".box "
      mustache "\n		--width: 100px;\n		--height: 100px;\n		position: absolute;\n		width: var(--width);\n		height: var(--height);\n		left: calc(50% - var(--width) / 2);\n		top: calc(50% - var(--height) / 2);\n		border-radius: 4px;\n		background-color: #ff3e00;\n		cursor: move;\n	"
  line_break
  line_break
  html tag="div" class="box" use:pannable=true on:panstart="handlePanStart" on:panmove="handlePanMove" on:panend="handlePanEnd" style="transform:\n		translate({$coords.x}px,{$coords.y}px)\n		rotate({$coords.x * 0.2}deg)"