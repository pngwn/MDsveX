root
  html tag="script"
    line_break
    paragraph
      text "import "
      mustache " time, elapsed "
      text " from \"./stores.js\";"
    line_break
    line_break
    paragraph
      text "const formatter = new Intl.DateTimeFormat(\"en\", "
      mustache "\n	hour12: true,\n	hour: \"numeric\",\n	minute: \"2-digit\",\n	second: \"2-digit\",\n"
      text ");\n"
  line_break
  line_break
  html tag="h1"
    paragraph
      text "The time is "
      mustache "formatter.format($time)"
  line_break
  line_break
  html tag="p"
    line_break
    paragraph
      text "This page has been open for\n	"
      mustache "$elapsed"
      text " "
      mustache "$elapsed === 1 ? 'second' : 'seconds'"