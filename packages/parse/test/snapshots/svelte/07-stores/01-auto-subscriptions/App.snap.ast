root
  html tag="script"
    line_break
    paragraph
      text "import "
      mustache " count "
      text " from \"./stores.js\";\nimport Incrementer from \"./Incrementer.svelte\";\nimport Decrementer from \"./Decrementer.svelte\";\nimport Resetter from \"./Resetter.svelte\";\n"
  line_break
  line_break
  html tag="h1"
    paragraph
      text "The count is "
      mustache "$count"
  line_break
  line_break
  html tag="Incrementer" self_closing=true
  line_break
  html tag="Decrementer" self_closing=true
  line_break
  html tag="Resetter" self_closing=true