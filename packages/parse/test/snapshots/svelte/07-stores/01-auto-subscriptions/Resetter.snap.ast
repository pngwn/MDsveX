root
  html tag="script"
    line_break
    paragraph
      text "import "
      mustache " count "
      text " from \"./stores.js\";"
    line_break
    line_break
    paragraph
      text "function reset() "
      mustache "\n	count.set(0);\n"
  line_break
  line_break
  html tag="button" on:click="reset"
    line_break
    paragraph
      text "reset\n"