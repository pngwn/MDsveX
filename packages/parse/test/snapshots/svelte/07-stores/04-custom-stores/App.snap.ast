root
  html tag="script"
    line_break
    paragraph
      text "import "
      mustache " count "
      text " from \"./stores.js\";\n"
  line_break
  line_break
  html tag="h1"
    paragraph
      text "The count is "
      mustache "$count"
  line_break
  line_break
  html tag="button" on:click="count.increment"
    paragraph
      text "+"
  line_break
  html tag="button" on:click="count.decrement"
    paragraph
      text "-"
  line_break
  html tag="button" on:click="count.reset"
    paragraph
      text "reset"