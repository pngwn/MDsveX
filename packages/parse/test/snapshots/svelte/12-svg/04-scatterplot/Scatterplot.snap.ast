root
  html tag="script"
    line_break
    paragraph
      text "import "
      mustache " onMount "
      text " from \"svelte\";\nimport "
      mustache " scaleLinear "
      text " from \"d3-scale\";"
    line_break
    line_break
    paragraph
      text "export let points;"
    line_break
    line_break
    paragraph
      text "let svg;\nlet width = 500;\nlet height = 200;"
    line_break
    line_break
    paragraph
      text "const padding = "
      mustache " top: 20, right: 40, bottom: 40, left: 25 "
      text ";"
    line_break
    line_break
    paragraph
      text "$: xScale = scaleLinear()\n	.domain("
      text "])\n	.range("
      text "]);"
    line_break
    line_break
    paragraph
      text "$: yScale = scaleLinear()\n	.domain("
      text "])\n	.range("
      text "]);"
    line_break
    line_break
    paragraph
      text "$: xTicks = width > 180 ? "
      text "] : "
      text "];"
    line_break
    line_break
    paragraph
      text "$: yTicks = height > 180 ? "
      text "] : "
      text "];"
    line_break
    line_break
    paragraph
      text "onMount(resize);"
    line_break
    line_break
    paragraph
      text "function resize() "
      mustache "\n	({ width, height } = svg.getBoundingClientRect());\n"
  line_break
  line_break
  html tag="svelte:window" on:resize="{resize}" self_closing=true
  line_break
  line_break
  html tag="svg" bind:this="svg"
    line_break
    html_comment " y axis "
    line_break
    html tag="g" class="axis y-axis"
      line_break
      paragraph
        mustache "#each yTicks as tick"
        text "			"
        html tag="g" class="tick tick-{tick}" transform="translate(0, {yScale(tick)})"
          text "				"
          html tag="line" x1="{padding.left}" x2="{xScale(22)}" self_closing=true
          text "				"
          html tag="text" x="{padding.left - 8}" y="+4"
            mustache "tick"
          text "			"
        text "		"
        mustache "/each"
        text "	"
  line_break
  line_break
  html tag="style"
    line_break
    paragraph
      text "svg "
      mustache "\n		width: 50%;\n		height: 50%;\n		float: left;\n	"