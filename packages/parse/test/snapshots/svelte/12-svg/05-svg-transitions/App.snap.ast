root
  html tag="script"
    line_break
    paragraph
      text "import "
      mustache " quintOut "
      text " from \"svelte/easing\";\nimport "
      mustache " fade, draw, fly "
      text " from \"svelte/transition\";\nimport "
      mustache " expand "
      text " from \"./custom-transitions.js\";\nimport "
      mustache " inner, outer "
      text " from \"./shape.js\";"
    line_break
    line_break
    paragraph
      text "let visible = true;\n"
  line_break
  line_break
  html tag="style"
    line_break
    paragraph
      text "svg "
      mustache "\n		width: 100%;\n		height: 100%;\n	"
      line_break
      line_break
      paragraph
        text "path "
        mustache "\n		fill: white;\n		opacity: 1;\n	"
      line_break
      line_break
      paragraph
        text "label "
        mustache "\n		position: absolute;\n		top: 1em;\n		left: 1em;\n	"
      line_break
      line_break
      paragraph
        text ".centered "
        mustache "\n		font-size: 20vw;\n		position: absolute;\n		left: 50%;\n		top: 50%;\n		transform: translate(-50%,-50%);\n		font-family: 'Overpass';\n		letter-spacing: 0.12em;\n		color: #676778;\n		font-weight: 100;\n	"
      line_break
      line_break
      paragraph
        text ".centered span "
        mustache "\n		will-change: filter;\n	"
  line_break
  line_break
  paragraph
    mustache "#if visible"
    text "	"
    html tag="svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 103 124"
      text "		"
      html tag="g" out:fade="{{duration: 200}}" opacity="0.2"
        text "			"
        html tag="path" in:expand="{{duration: 400, delay: 1000, easing: quintOut}}" style="stroke: #ff3e00; fill: #ff3e00; stroke-width: 50;" d="outer" self_closing=true
        text "			"
        html tag="path" in:draw="{{duration: 1000}}" style="stroke:#ff3e00; stroke-width: 1.5" d="inner" self_closing=true
        text "		"
      text "	"