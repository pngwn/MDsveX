root
  html tag="script"
  line_break
  line_break
  html tag="style"
  line_break
  line_break
  html tag="svg" viewBox="-50 -50 100 100"
    line_break
    html tag="circle" class="clock-face" r="48" self_closing=true
    line_break
    line_break
    html_comment " markers "
    line_break
    paragraph
      mustache "#each [0, 5, 10, 15, 20, 25, 30, 35, 40, 45, 50, 55] as minute"
      soft_break
      text "		"
      html tag="line" class="major" y1="35" y2="45" transform="rotate({30 * minute})" self_closing=true
    line_break
    line_break
    paragraph
      mustache "#each [1, 2, 3, 4] as offset"
      soft_break
      text "			"
      html tag="line" class="minor" y1="42" y2="45" transform="rotate({6 * (minute + offset)})" self_closing=true
      soft_break
      text "		"
      mustache "/each"
      soft_break
      text "	"
      mustache "/each"
    line_break
    line_break
    html_comment " hour hand "
    line_break
    html tag="line" class="hour" y1="2" y2="-20" transform="rotate({30 * hours + minutes / 2})" self_closing=true
    line_break
    line_break
    html_comment " minute hand "
    line_break
    html tag="line" class="minute" y1="4" y2="-30" transform="rotate({6 * minutes + seconds / 10})" self_closing=true
    line_break
    line_break
    html_comment " second hand "
    line_break
    html tag="g" transform="rotate({6 * seconds})"
      line_break
      html tag="line" class="second" y1="10" y2="-38" self_closing=true
      line_break
      html tag="line" class="second-counterweight" y1="10" y2="2" self_closing=true
      line_break
    line_break