root
  html tag="script" context="module"
    line_break
    paragraph
      text "const elements = new Set();"
    line_break
    line_break
    paragraph
      text "export function stopAll() "
      mustache "\n	elements.forEach((element) => {\n		element.pause();\n	});\n"
  line_break
  line_break
  html tag="script"
    line_break
    paragraph
      text "import "
      mustache " onMount "
      text " from 'svelte';"
      line_break
      line_break
      paragraph
        text "export let src;\n	export let title;\n	export let composer;\n	export let performer;"
      line_break
      line_break
      paragraph
        text "let audio;\n	let paused = true;"
      line_break
      line_break
      paragraph
        text "onMount(() => "
        mustache "\n		elements.add(audio);\n		return () => elements.delete(audio);\n	"
        text ");"
      line_break
      line_break
      paragraph
        text "function stopOthers() "
        mustache "\n		elements.forEach(element => {\n			if (element !== audio) element.pause();\n		});\n	"
  line_break
  line_break
  html tag="style"
    line_break
    paragraph
      text "article "
      mustache " margin: 0 0 1em 0; max-width: 800px "
      text "	h2, p "
      mustache " margin: 0 0 0.3em 0; "
      text "	audio "
      mustache " width: 100%; margin: 0.5em 0 1em 0; "
      text "	.playing "
      mustache " color: #ff3e00; "
  line_break
  line_break
  html tag="article" class:playing="!paused"
    line_break
    html tag="h2"
      paragraph
        mustache "title"
    line_break
    html tag="p"
      html tag="strong"
        paragraph
          mustache "composer"
      paragraph
        text "/ performed by "
        mustache "performer"
    line_break
    line_break
    html tag="audio" bind:this="audio" bind:paused=true on:play="stopOthers" controls=true src="src"
    line_break