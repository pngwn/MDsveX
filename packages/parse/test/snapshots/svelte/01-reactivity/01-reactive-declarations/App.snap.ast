root
  html tag="script"
  line_break
  line_break
  html tag="button" on:click="handleClick"
    line_break
    paragraph
      text "Count: "
      mustache "count"
      soft_break
  line_break
  line_break
  html tag="p"
    paragraph
      mustache "count"
      text " "
      text "* 2 = "
      mustache "doubled"
  line_break
  html tag="p"
    paragraph
      mustache "doubled"
      text " "
      text "* 2 = "
      mustache "quadrupled"