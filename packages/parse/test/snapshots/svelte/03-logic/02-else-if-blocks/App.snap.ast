root
  html tag="script"
  line_break
  line_break
  svelte_block tag="if"
    svelte_branch tag="if" "x > 10"
      line_break
      html tag="p"
        paragraph
          mustache "x"
          text " is greater than 10"
      line_break
      paragraph
        mustache ":else if 5 > x"
        soft_break
        text "	"
        html tag="p"
          mustache "x"
          text " is less than 5"
        line_break
        paragraph
          mustache ":else"
          soft_break
          text "	"
          html tag="p"
            mustache "x"
            text " is between 5 and 10"
        line_break
        paragraph
          mustache "/if"