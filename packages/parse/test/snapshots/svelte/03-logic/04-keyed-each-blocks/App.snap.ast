root
  html tag="script"
  line_break
  line_break
  html tag="button" on:click=[object Object]
    line_break
    paragraph
      text "Remove first thing"
      soft_break
  line_break
  line_break
  html tag="div" style="display: grid; grid-template-columns: 1fr 1fr; grip-gap: 1em"
    line_break
    html tag="div"
      line_break
      html tag="h2"
        paragraph
          text "Keyed"
      line_break
      paragraph
        mustache "#each things as thing (thing.id)"
        soft_break
        text "			"
        html tag="Thing" current=[object Object] self_closing=true
        soft_break
        text "		"
        mustache "/each"
        soft_break
        text "	"
    line_break
    line_break
    html tag="div"
      line_break
      html tag="h2"
        paragraph
          text "Unkeyed"
      line_break
      paragraph
        mustache "#each things as thing"
        soft_break
        text "			"
        html tag="Thing" current=[object Object] self_closing=true
        soft_break
        text "		"
        mustache "/each"
        soft_break
        text "	"
    line_break