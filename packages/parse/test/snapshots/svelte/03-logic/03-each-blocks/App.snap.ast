root
  html tag="script"
    line_break
    paragraph
      text "let cats = "
      text "	"
      mustache " id: \"J---aiyznGQ\", name: \"Keyboard Cat\" "
      text ",\n	"
      mustache " id: \"z_AbfPXTKms\", name: \"Maru\" "
      text ",\n	"
      mustache " id: \"OUtn3pvWmpg\", name: \"Henri The Existential Cat\" "
      text ",\n"
      text "];\n"
  line_break
  line_break
  html tag="h1"
    paragraph
      text "The Famous Cats of YouTube"
  line_break
  line_break
  html tag="ul"
    line_break
    paragraph
      mustache "#each cats as { id, name }, i"
      text "		"
      html tag="li"
        html tag="a" target="_blank" href="https://www.youtube.com/watch?v={id}"
          text "			"
          mustache "i + 1"
          text ": "
          mustache "name"
          text "		"
      text "	"
      mustache "/each"