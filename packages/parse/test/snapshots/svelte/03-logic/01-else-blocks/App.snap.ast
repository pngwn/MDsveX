root
  html tag="script"
  line_break
  line_break
  svelte_block tag="if"
    svelte_branch tag="if" "user.loggedIn"
      line_break
      html tag="button" on:click=[object Object]
        line_break
        paragraph
          text "Log out"
          soft_break
          text "	"
      line_break
      paragraph
        mustache ":else"
        soft_break
        text "	"
        html tag="button" on:click=[object Object]
          soft_break
          text "		Log in"
          soft_break
          text "	"
        line_break
        paragraph
          mustache "/if"