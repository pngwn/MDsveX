root
  html tag="script"
  line_break
  line_break
  html tag="style"
  line_break
  line_break
  html tag="label"
    line_break
    html tag="input" type="checkbox" bind:checked="big"
      line_break
      paragraph
        text "big"
        soft_break
  line_break
  line_break
  html tag="div" class:big=true
    line_break
    paragraph
      text "some "
      mustache "big ? 'big' : 'small'"
      text " text"
      soft_break