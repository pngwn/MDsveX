root
  html tag="svelte:options" immutable=true self_closing=true
  line_break
  line_break
  html tag="script"
    line_break
    paragraph
      text "import ImmutableTodo from \"./ImmutableTodo.svelte\";\nimport MutableTodo from \"./MutableTodo.svelte\";"
    line_break
    line_break
    paragraph
      text "let todos = "
      text "	"
      mustache " id: 1, done: true, text: \"wash the car\" "
      text ",\n	"
      mustache " id: 2, done: false, text: \"take the dog for a walk\" "
      text ",\n	"
      mustache " id: 3, done: false, text: \"mow the lawn\" "
      text ",\n"
      text "];"
    line_break
    line_break
    paragraph
      text "function toggle(id) "
      mustache "\n	todos = todos.map((todo) => {\n		if (todo.id === id) {\n			// return a new object\n			return {\n				id,\n				done: !todo.done,\n				text: todo.text,\n			};\n		}\n\n		// return the same object\n		return todo;\n	});\n"
  line_break
  line_break
  html tag="h2"
    paragraph
      text "Immutable"
  line_break
  paragraph
    mustache "#each todos as todo"
    text "	"
    html tag="ImmutableTodo" todo="todo" on:click="{() => toggle(todo.id)}" self_closing=true
    mustache "/each"