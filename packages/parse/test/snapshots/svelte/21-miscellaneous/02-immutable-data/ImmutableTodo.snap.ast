root
  html tag="svelte:options" immutable=true self_closing=true
  line_break
  line_break
  html tag="script"
  line_break
  line_break
  html tag="style"
  line_break
  line_break
  html_comment " the text will flash red whenever\n		the `todo` object changes "
  line_break
  html tag="div" bind:this=[object Object] on:click=true
    line_break
    paragraph
      mustache "todo.done ? '👍': ''"
      text " "
      mustache "todo.text"
      soft_break
  line_break