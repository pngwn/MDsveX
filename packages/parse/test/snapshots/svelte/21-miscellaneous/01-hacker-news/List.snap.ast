root
  html tag="script"
    line_break
    paragraph
      text "import "
      mustache " beforeUpdate "
      text " from \"svelte\";\nimport Summary from \"./Summary.svelte\";"
    line_break
    line_break
    paragraph
      text "const PAGE"
      text "_SIZE = 20;"
    line_break
    line_break
    paragraph
      text "export let page;"
    line_break
    line_break
    paragraph
      text "let items;\nlet offset;"
    line_break
    line_break
    paragraph
      text "$: fetch("
      code_span "https://node-hnapi.herokuapp.com/news?page=${page}"
      text ")\n	.then((r) => r.json())\n	.then((data) => "
      mustache "\n		items = data;\n		offset = PAGE_SIZE * (page - 1);\n		window.scrollTo(0, 0);\n	"
      text ");\n"
  line_break
  line_break
  html tag="style"
    line_break
    paragraph
      text "a "
      mustache "\n		padding: 2em;\n		display: block;\n	"
      line_break
      line_break
      paragraph
        text ".loading "
        mustache "\n		opacity: 0;\n		animation: 0.4s 0.8s forwards fade-in;\n	"
      line_break
      line_break
      paragraph
        text "@keyframes fade-in "
        mustache "\n		from { opacity: 0; }\n		to { opacity: 1; }\n	"
  line_break
  line_break
  paragraph
    mustache "#if items"
    text "	"
    mustache "#each items as item, i"
    text "		"
    html tag="Summary" item="item" i="i" offset="offset" self_closing=true
    text "	"
    mustache "/each"