root
  html tag="style"
    line_break
    paragraph
      text "button "
      mustache "\n		font-family: 'Comic Sans MS';\n		font-size: 2em;\n		padding: 0.5em 1em;\n		color: royalblue;\n		background: gold;\n		border-radius: 1em;\n		box-shadow: 2px 2px 4px rgba(0,0,0,0.5);\n	"
  line_break
  line_break
  html tag="button" on:click=true
    line_break
    paragraph
      text "Click me\n"