root
  html tag="script"
  line_break
  line_break
  html tag="label"
    line_break
    html tag="input" type="checkbox" bind:checked=[object Object]
      line_break
      paragraph
        text "visible"
        soft_break
  line_break
  line_break
  paragraph
    mustache "#if visible"
    soft_break
    text "	"
    html tag="p" in:typewriter=true
      soft_break
      text "		The quick brown fox jumps over the lazy dog"
      soft_break
      text "	"
    soft_break
    mustache "/if"