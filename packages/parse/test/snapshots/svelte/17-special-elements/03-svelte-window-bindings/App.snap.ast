root
  html tag="script"
  line_break
  line_break
  html tag="svelte:window" bind:scrollY=[object Object] self_closing=true
  line_break
  line_break
  html tag="a" class="parallax-container" href="https://www.firewatchgame.com"
    line_break
    paragraph
      mustache "#each [0, 1, 2, 3, 4, 5, 6, 7, 8] as layer"
      soft_break
      text "		"
      html tag="img" style="transform: translate(0,{-y * layer / (layers.length - 1)}px)" src="https://www.firewatchgame.com/images/parallax/parallax{layer}.png" alt="parallax layer {layer}"
        soft_break
        text "	"
        mustache "/each"
        soft_break