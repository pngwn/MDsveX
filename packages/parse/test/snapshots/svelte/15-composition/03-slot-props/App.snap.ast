root
  html tag="script"
  line_break
  line_break
  html tag="style"
  line_break
  line_break
  html tag="Hoverable" let:hovering=[object Object]
    line_break
    html tag="div" class:active=true
      line_break
      paragraph
        mustache "#if active"
        soft_break
        text "			"
        html tag="p"
          text "I am being hovered upon."
        soft_break
        text "		"
        mustache ":else"
        soft_break
        text "			"
        html tag="p"
          text "Hover over me"
          text "!"
        soft_break
        text "		"
        mustache "/if"
        soft_break
        text "	"
    line_break
  line_break
  line_break
  html tag="Hoverable" let:hovering=[object Object]
    line_break
    html tag="div" class:active=true
