root
  html tag="script"
    line_break
    paragraph
      text "import Modal from \"./Modal.svelte\";"
    line_break
    line_break
    paragraph
      text "let showModal = false;\n"
  line_break
  line_break
  html tag="button" on:click="{() => showModal = true}"
    line_break
    paragraph
      text "show modal\n"
  line_break
  line_break
  paragraph
    mustache "#if showModal"
    text "	"
    text tag="Modal" on:close="{() => showModal = false}" "<Modal on:close=\"{() => showModal = false}\">\n"
    text "		"
    html tag="h2" slot="header"
      text "			modal\n			"
      html tag="small"
        html tag="em"
          text "adjective"
        text "  mod·al \\ˈmō-dəl\\</small>\n		"