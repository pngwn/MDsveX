root
  html tag="script"
    line_break
    paragraph
      text "import "
      mustache " title, comicSans, box "
      text " from \"./styles.js\";\n"
  line_break
  line_break
  html tag="div" class="{title} {comicSans}"
    line_break
    html tag="h1"
      line_break
      html tag="div" class="box"
        line_break
        html tag="div" class="box"
          line_break
          html tag="div" class="box"
            paragraph
              text "CSS"
          line_break
          paragraph
            text "in JS\n			"
        line_break
        paragraph
          text "in HTML\n		"
      line_break
    line_break